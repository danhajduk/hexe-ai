{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synthia.local/schemas/addon-manifest.schema.json",
  "title": "Synthia Addon Manifest",
  "description": "Addon artifact manifest.json contract used by Core layout checks and standalone runtime-default extraction.",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "core_min_version",
    "publisher_id",
    "permissions"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "core_min_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "core_max_version": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "publisher_id": {
      "type": "string",
      "minLength": 1
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "filesystem.read",
          "filesystem.write",
          "network.egress",
          "network.ingress",
          "process.spawn",
          "system.metrics.read",
          "mqtt.publish",
          "mqtt.subscribe",
          "network.outbound",
          "network.inbound",
          "mqtt.client"
        ]
      }
    },
    "package_profile": {
      "type": "string",
      "enum": [
        "embedded_addon",
        "standalone_service"
      ]
    },
    "runtime_defaults": {
      "type": "object",
      "properties": {
        "bind_localhost": {
          "type": "boolean",
          "default": true
        },
        "ports": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "host",
              "container"
            ],
            "properties": {
              "host": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              },
              "container": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              },
              "proto": {
                "type": "string",
                "enum": [
                  "tcp",
                  "udp"
                ],
                "default": "tcp"
              },
              "purpose": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          },
          "default": []
        }
      }
    }
  },
  "additionalProperties": true
}
