{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synthia.local/schemas/runtime.schema.json",
  "title": "Synthia Standalone Runtime State",
  "description": "Supervisor-authored runtime.json contract for standalone addon services.",
  "type": "object",
  "required": [
    "addon_id",
    "state"
  ],
  "properties": {
    "ssap_version": {
      "type": "string",
      "default": "1.0"
    },
    "addon_id": {
      "type": "string",
      "minLength": 1
    },
    "active_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "state": {
      "type": "string",
      "description": "Supervisor runtime state (typically running, stopped, or error)."
    },
    "error": {
      "type": [
        "string",
        "null"
      ]
    },
    "previous_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "rollback_available": {
      "type": "boolean",
      "default": false
    },
    "last_error": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_applied_desired_revision": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_applied_compose_digest": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_force_rebuild_revision": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
